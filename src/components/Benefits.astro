---
const title = "Beneficios";

const description =
  "Descubre cómo BUFONIO transforma la comunicación en tu equipo.";

const benefits = [
  {
    title: "Información honesta y directa",
    text: "Accede a la realidad interna de tu empresa sin filtros jerárquicos, obteniendo datos valiosos para fortalecer tu liderazgo y cultura.",
  },
  {
    title: "Gestión libre de conflictos",
    text: "Recibe críticas constructivas procesadas por IA que eliminan la confrontación, permitiéndote enfocar tu energía en las soluciones.",
  },
  {
    title: "Cultura de alto rendimiento",
    text: "Mejora la retención de talento y la productividad al resolver problemas reales antes de que se conviertan en crisis.",
  },
];
---

<section
  id="benefits"
  class="relative overflow-hidden p-6 md:p-12 min-h-[90vh] flex flex-col items-center justify-center bg-white"
>
  <div class="relative z-10 max-w-7xl mx-auto">
    <div class="mb-10 max-w-4xl">
      <h2
        class="text-5xl md:text-7xl font-extrabold tracking-[-0.05em] leading-[0.95] text-black mb-10 flex flex-col items-center justify-center text-center md:items-start md:text-left"
      >
        <span class="block">{title}</span>
        <span class="text-black/30">sin esfuerzo.</span>
      </h2>
    </div>
    <div class="flex flex-col gap-6 md:gap-8 max-w-7xl mx-auto">
      {
        benefits.map((benefit) => (
          <article class="p-8 md:p-12 duration-500 hover:-translate-y-2">
            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-20">
              <div class="md:w-1/3 w-full">
                <h4 class="text-3xl md:text-4xl font-bold tracking-[-0.05em] leading-[0.95] text-black ">
                  {benefit.title}
                </h4>
              </div>
              <div class="md:w-2/3 w-full">
                <p class="text-lg md:text-xl text-black/80 font-medium balance">
                  {benefit.text}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
