---
import Logo from "@/components/icons/Logo.astro";
import Menu from "@/components/icons/Menu.astro";
import Exit from "@/components/icons/Exit.astro";

const navLinks = [
  { href: "#", text: "Inicio" },
  { href: "#how-it-works", text: "Cómo funciona" },
  { href: "#benefits", text: "Beneficios" },
];

const loginURL = "https://bufonio-app.vercel.app";
const registerURL = "https://bufonio-app.vercel.app/public/register";

const loginText = "Iniciar sesión";
const registerText = "Registrarse";
---

<header id="header-nav" class="fixed top-0 left-0 right-0 w-full bg-white z-50">
  <div class="max-w-6xl mx-auto px-4 relative z-50 bg-white">
    <nav class="flex items-center justify-between h-16 w-full relative">
      <a href="#" class="flex-shrink-0">
        <Logo height="40" width="40" />
      </a>

      <div
        class="hidden lg:flex gap-2 absolute left-1/2 transform -translate-x-1/2"
      >
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-md hover:bg-black/5 transition py-1.5 px-3 text-base font-medium"
            >
              {link.text}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-3 ml-auto">
        <a
          href={loginURL}
          class="hidden lg:block rounded-md hover:bg-black/5 py-1.5 px-3 text-base font-medium"
        >
          {loginText}
        </a>

        <a
          href={registerURL}
          class="rounded-md bg-black text-white font-bold py-1.5 px-4 text-base"
        >
          {registerText}
        </a>

        <button
          id="menu"
          class="lg:hidden flex items-center justify-center w-9 h-9 rounded-md hover:bg-[#f2f2f2] transition"
          aria-label="Menu"
        >
          <div id="icon-menu"><Menu /></div>
          <div id="icon-exit" class="hidden"><Exit /></div>
        </button>
      </div>
    </nav>
  </div>

  <div
    id="mobile-dropdown"
    class="hidden fixed inset-0 bg-white z-40 flex flex-col pt-16"
  >
    <div class="flex-1 flex flex-col justify-center px-8">
      <nav class="flex flex-col space-y-2 gap-15">
        {
          navLinks.map((link) => (
            <a href={link.href} class="text-[20px] font-medium">
              {link.text}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="p-8 flex justify-center">
      <a href={loginURL} class="text-[20px] font-medium">
        {loginText}
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuButton = document.getElementById("menu");
    const dropdown = document.getElementById("mobile-dropdown");
    const iconOpen = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-exit");
    const body = document.body;

    if (!menuButton || !dropdown || !iconOpen || !iconClose) return;

    const toggleMenu = () => {
      const isOpening = dropdown.classList.contains("hidden");

      dropdown.classList.toggle("hidden");
      iconOpen.classList.toggle("hidden");
      iconClose.classList.toggle("hidden");

      if (isOpening) {
        body.style.overflow = "hidden";
      } else {
        body.style.overflow = "";
      }
    };

    menuButton.addEventListener("click", toggleMenu);

    dropdown.addEventListener("click", (event) => {
      const target = (event.target as HTMLElement).closest("a");
      if (target) {
        dropdown.classList.add("hidden");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
        body.style.overflow = "";
      }
    });
  });
</script>
